<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calificar Playa"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calificación General"
            android:layout_marginTop="20dp"/>
        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="1.0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado de Limpieza"
            android:layout_marginTop="15dp"/>
        <Spinner
            android:id="@+id/spinnerLimpieza"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/opciones_limpieza" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nivel de Afluencia"
            android:layout_marginTop="15dp"/>
        <Spinner
            android:id="@+id/spinnerAfluencia"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/opciones_afluencia" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clima Actual"
            android:layout_marginTop="15dp"/>
        <Spinner
            android:id="@+id/spinnerClima"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/opciones_clima" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seguridad"
            android:layout_marginTop="15dp"/>
        <Spinner
            android:id="@+id/spinnerSeguridad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/opciones_seguridad" />

        <Button
            android:id="@+id/btnSubirFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subir Foto"
            android:layout_marginTop="20dp"
            android:backgroundTint="#607D8B"/>

        <EditText
            android:id="@+id/editComentario"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Cuéntanos más..."
            android:gravity="top"
            android:padding="10dp"
            android:layout_marginTop="15dp"
            android:background="@android:drawable/editbox_background"/>

        <Button
            android:id="@+id/btnEnviarCalificacion"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ENVIAR REPORTE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:backgroundTint="#4CAF50"/>

    </LinearLayout>
</ScrollView>